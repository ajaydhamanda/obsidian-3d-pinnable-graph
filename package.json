{
  "name": "3d-pinnable-graph",
  "version": "1.0.0",
  "description": "Explore your vault as a 3D force-directed graph and pin nodes in place while everything else moves elastically around them.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "deploy": "npm run build && node scripts/deploy.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [],
  "author": "Ajay Dhamanda",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/three": "^0.185.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.19.11",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "3d-force-graph": "^1.73.3",
    "three": "^0.185.1",
    "three-spritetext": "^1.8.2"
  }
}
